package main

import (
	"context"
	"flag"
	"fmt"
	"log"
	"os"
	"os/signal"
	"strconv"
	"syscall"
	"time"
)

func main() {
	// Dispatch CLI subcommands before flag.Parse() because tool parameter
	// names are dynamic and would be rejected by the flag package.
	if len(os.Args) > 1 {
		switch os.Args[1] {
		case "tools":
			srv := NewServer("", "")
			srv.ListTools(os.Stdout)
			return
		case "call":
			srv := NewServer("", os.Getenv("{{.Auth.EnvVar}}"))
			if err := srv.RunCLI(os.Args[2:]); err != nil {
				fmt.Fprintf(os.Stderr, "Error: %v\n", err)
				os.Exit(1)
			}
			return
		}
	}

	transport := flag.String("transport", "stdio", "Transport type: stdio or sse")
	port := flag.Int("port", 8080, "Port for SSE transport")
	baseURL := flag.String("base-url", "{{.BaseURL}}", "Base URL of the API")
	flag.Parse()

	apiKey := os.Getenv("{{.Auth.EnvVar}}")

	srv := NewServer(*baseURL, apiKey)

	switch *transport {
	case "stdio":
		if err := srv.ServeStdio(); err != nil {
			log.Fatal(err)
		}
	case "sse":
		shutdownTimeout := 30 * time.Second
		if v := os.Getenv("SHUTDOWN_TIMEOUT_SECONDS"); v != "" {
			if n, err := strconv.Atoi(v); err == nil && n > 0 {
				shutdownTimeout = time.Duration(n) * time.Second
			}
		}

		ctx, stop := signal.NotifyContext(context.Background(), syscall.SIGTERM, syscall.SIGINT)
		defer stop()

		addr := fmt.Sprintf(":%d", *port)
		log.Printf("Starting SSE server on %s", addr)
		if err := srv.ServeSSE(ctx, addr, shutdownTimeout); err != nil {
			log.Fatal(err)
		}
	default:
		fmt.Fprintf(os.Stderr, "unknown transport: %s\n", *transport)
		os.Exit(1)
	}
}
