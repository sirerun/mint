FROM golang:1.23-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /{{.Name}} .

FROM gcr.io/distroless/static-debian12

COPY --from=builder /{{.Name}} /usr/local/bin/{{.Name}}

USER nonroot:nonroot

ENTRYPOINT ["{{.Name}}"]
CMD ["--transport", "stdio"]
